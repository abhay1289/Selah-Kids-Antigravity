# Supabase Configuration (for /admin CMS)
#
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ADMIN DASHBOARD RUNS IN OFFLINE MODE IF THESE ARE BLANK — safe to deploy without them.
# In offline mode the `src/lib/supabase.ts` mock short-circuits all DB calls so pages boot,
# and `src/middleware.ts` skips server-side auth for /admin/*.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY key. Never expose via NEXT_PUBLIC_*. Used by createAdminClient()
# in src/lib/supabase.ts for privileged operations (e.g. bypassing RLS).
SUPABASE_SERVICE_ROLE_KEY=
